# Required — copy this file to .env and fill in your values
# Never commit .env to version control

# IMAP credentials
IMAP_SERVER=mail.example.com
EMAIL_USER=you@example.com
EMAIL_PASS=your_password_here

# Folder names (adjust to match your mail server)
INBOX_FOLDER=INBOX
JUNK_FOLDER=Junk

# Comma-separated folders used as HAM (legitimate mail) training examples.
# The Sent folder is the most valuable — it contains people you actually write to.
# Common alternatives: "Sent Items", "Sent Messages", Archive, INBOX.Sent
HAM_FOLDERS=Sent

# Ollama model (must be available via `ollama list`)
# Recommended: qwen2.5:3b — best multilingual quality (incl. Czech) at small size
# Upgrade option: qwen2.5:7b — better accuracy, needs ~5 GB RAM
MODEL_NAME=qwen2.5:3b

# ChromaDB path (relative to working directory)
DB_PATH=./spam_memory

# Tuning
MAX_JUNK_EMAILS=300   # how many recent junk emails to keep in memory
MAX_HAM_EMAILS=200    # how many recent HAM emails to keep per folder
MAX_EMAIL_CHARS=1000  # max characters to read from each email body
SIMILAR_RESULTS=5     # how many examples of each type to pass to the LLM
